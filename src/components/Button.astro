---
interface Props {
  variant?: "primary" | "ghost";
  href?: string;
  arrow?: "right" | "external" | false;
  external?: boolean;
  class?: string;
}

const {
  variant = "primary",
  href,
  arrow = false,
  external = false,
  class: className,
} = Astro.props;

const Tag = href ? "a" : "button";
const rel = external ? "noopener noreferrer" : undefined;
const target = external ? "_blank" : undefined;
---

<Tag
  class:list={["btn", `btn-${variant}`, "mono", className]}
  href={href}
  target={target}
  rel={rel}
>
  <slot />
  {
    arrow === "right" && (
      <svg
        class="btn-arrow"
        width="14"
        height="14"
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M3 8h10M9 4l4 4-4 4" />
      </svg>
    )
  }
  {
    arrow === "external" && (
      <svg
        class="btn-arrow"
        width="13"
        height="13"
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M5.5 10.5 11 5M6.5 5H11v4.5" />
      </svg>
    )
  }
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1rem;
    font-size: 13px;
    line-height: 1;
    border-radius: 8px;
    background: transparent;
    cursor: pointer;
    text-decoration: none;
    transition:
      background 150ms ease,
      border-color 150ms ease,
      color 150ms ease;
  }

  .btn-primary {
    border: 1px solid var(--accent);
    color: var(--accent);
  }

  .btn-primary:hover {
    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }

  .btn-ghost {
    border: 1px solid var(--border);
    color: var(--text-muted);
  }

  .btn-ghost:hover {
    border-color: var(--text-faint);
    color: var(--text);
  }

  .btn:focus-visible {
    outline: 1px solid var(--accent);
    outline-offset: 2px;
  }

  .btn-arrow {
    flex-shrink: 0;
  }
</style>
