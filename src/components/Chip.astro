---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<span class:list={["chip", "mono", className]}><slot /></span>

<style>
  .chip {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.6rem;
    font-size: 11px;
    letter-spacing: 0.02em;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: 6px;
    white-space: nowrap;
  }
</style>
