---
import Section from "./Section.astro";
import Button from "./Button.astro";
import StatusDot from "./StatusDot.astro";
import Sparkline from "./Sparkline.astro";
import SystemPanel from "./SystemPanel.astro";
import { profile } from "../data/profile";
import { projects } from "../data/projects";

const liveCount = projects.filter((p) => p.status === "live").length;
const devCount = projects.filter((p) => p.status === "dev").length;
const pulse = projects.find((p) => p.short === "PULSE");
---

<Section id="top">
  <div class="hero">
    <div class="hero-main">
      <p class="kicker mono" data-reveal>
        <StatusDot status="live" />
        <span>SYSTEM ONLINE · {liveCount} LIVE, {devCount} IN DEV</span>
      </p>

      <h1 class="headline" data-reveal style="--reveal-delay:60ms">{profile.headline}</h1>

      <p class="subline" data-reveal style="--reveal-delay:120ms">{profile.subline}</p>

      <div class="ctas" data-reveal style="--reveal-delay:180ms">
        <Button variant="primary" href="#work">Explore work</Button>
        <Button variant="ghost" href={pulse?.url} external arrow="external">
          Launch Pulse
        </Button>
      </div>
    </div>

    <div class="hero-aside" data-reveal style="--reveal-delay:240ms">
      <SystemPanel />
    </div>
  </div>

  <div class="spark-wrap">
    <Sparkline />
  </div>
</Section>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) clamp(248px, 30%, 320px);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }

  .kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin: 0;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-faint);
  }

  .headline {
    max-width: 600px;
    margin: 1.5rem 0 0;
    font-size: clamp(28px, 5vw, 44px);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  .subline {
    max-width: 460px;
    margin: 1.25rem 0 0;
    font-size: 16px;
    color: var(--text-muted);
  }

  .ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  /* Sparkline spans the full hero width as a baseline. */
  .spark-wrap {
    margin-top: clamp(2.5rem, 6vh, 4rem);
  }

  @media (max-width: 860px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
