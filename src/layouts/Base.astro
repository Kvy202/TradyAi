---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "tradyai — AI systems for trading, crypto & market intelligence",
  description = "Tools that read markets, decode crowd behaviour, and automate decisions — designed, built, and deployed solo.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <slot />
  </body>
</html>
