---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Section from "../components/Section.astro";
import Hero from "../components/Hero.astro";
import ProductCard from "../components/ProductCard.astro";
import StatusRow from "../components/StatusRow.astro";
import Chip from "../components/Chip.astro";
import Button from "../components/Button.astro";
import Terminal from "../components/Terminal.tsx";
import Ticker from "../components/Ticker.tsx";
import { projects } from "../data/projects";
import { profile, capabilities } from "../data/profile";

const liveProjects = projects.filter((p) => p.status === "live");
const devProjects = projects.filter((p) => p.status === "dev");

// Only render socials that are actually set in profile.ts
const socials = [
  { label: "GitHub", href: profile.github },
  { label: "X", href: profile.x },
  { label: "LinkedIn", href: profile.linkedin },
].filter((s) => s.href);
---

<Base>
  <Ticker client:load />

  <Nav />

  <Terminal client:visible />

  <main>
    <Hero />

    <Section id="work" index="01" label="work" desc="live products">
      <div class="cards">
        {liveProjects.map((p) => <ProductCard project={p} />)}
      </div>
    </Section>

    <Section id="building" index="02" label="building" desc="in development">
      <div class="building-panel">
        {devProjects.map((p) => <StatusRow project={p} />)}
      </div>
    </Section>

    <Section index="03" label="capabilities" desc="stack & focus">
      <ul class="chips">
        {capabilities.map((c) => <li><Chip>{c}</Chip></li>)}
      </ul>
    </Section>

    <Section id="about" index="04" label="about" desc="the short version">
      <div class="about-grid">
        <p class="about-copy">{profile.about}</p>
        <ul class="about-facts mono">
          <li><span class="fk">focus</span><span class="fv">trading · crypto · market psychology</span></li>
          <li><span class="fk">status</span><span class="fv">{liveProjects.length} live · {devProjects.length} in dev</span></li>
          <li><span class="fk">stack</span><span class="fv">{capabilities.length} technologies</span></li>
          <li><span class="fk">mode</span><span class="fv">solo · end-to-end</span></li>
        </ul>
      </div>
    </Section>

    <Section id="contact" index="05" label="contact" desc="get in touch">
      <div class="contact-card">
        <p class="contact-line">{profile.contactLine}</p>
        <div class="contact-actions">
          <Button variant="primary" href={`mailto:${profile.email}`}>
            {profile.email}
          </Button>
        </div>
        <ul class="contact-links mono">
          {
            socials.map((s) => (
              <li>
                <a href={s.href} target="_blank" rel="noopener noreferrer">{s.label}</a>
              </li>
            ))
          }
        </ul>
      </div>
    </Section>
  </main>

  <Footer />
</Base>

<style>
  /* Work — two cards side by side, stacked on mobile */
  .cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 720px) {
    .cards {
      grid-template-columns: 1fr;
    }
  }

  /* Building — one bordered panel holding the terminal-style status rows */
  .building-panel {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  /* Capabilities — flat mono chip strip, no colour */
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  /* About — prose + a compact facts column */
  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) clamp(220px, 30%, 300px);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  .about-copy {
    max-width: 640px;
    margin: 0;
    color: var(--text-muted);
  }

  .about-facts {
    margin: 0;
    padding: 0;
    list-style: none;
    font-size: 12px;
  }

  .about-facts li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.7rem 0;
    border-top: 1px solid var(--border-soft);
  }

  .about-facts li:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .about-facts .fk {
    color: var(--text-faint);
    flex-shrink: 0;
  }

  .about-facts .fv {
    color: var(--text-muted);
    text-align: right;
  }

  @media (max-width: 720px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Contact — tidy bordered block */
  .contact-card {
    max-width: 520px;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
  }

  .contact-line {
    margin: 0;
    color: var(--text-muted);
  }

  .contact-actions {
    margin-top: 1.25rem;
  }

  .contact-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin: 1.75rem 0 0;
    padding: 0;
    list-style: none;
    font-size: 13px;
  }

  .contact-links a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 150ms ease;
  }

  .contact-links a:hover {
    color: var(--text);
  }

  .contact-links a:focus-visible {
    outline: 1px solid var(--accent);
    outline-offset: 3px;
    border-radius: 3px;
  }
</style>
