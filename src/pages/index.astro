---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Section from "../components/Section.astro";
import Hero from "../components/Hero.astro";
import ProductCard from "../components/ProductCard.astro";
import StatusRow from "../components/StatusRow.astro";
import Chip from "../components/Chip.astro";
import Button from "../components/Button.astro";
import Terminal from "../components/Terminal.tsx";
import { projects } from "../data/projects";
import { profile, capabilities } from "../data/profile";

const liveProjects = projects.filter((p) => p.status === "live");
const devProjects = projects.filter((p) => p.status === "dev");

// Only render socials that are actually set in profile.ts
const socials = [
  { label: "GitHub", href: profile.github },
  { label: "X", href: profile.x },
  { label: "LinkedIn", href: profile.linkedin },
].filter((s) => s.href);
---

<Base>
  {/* Ticker strip — Phase 7 replaces this with <Ticker client:load />. */}
  {/* No fake numbers: values are dim placeholders until the live island mounts. */}
  <div class="ticker" aria-label="Crypto ticker">
    <div class="ticker-inner mono">
      <span class="ticker-item"><span class="sym">BTC</span><span class="val">—</span></span>
      <span class="ticker-item"><span class="sym">ETH</span><span class="val">—</span></span>
      <span class="ticker-item"><span class="sym">SOL</span><span class="val">—</span></span>
    </div>
  </div>

  <Nav />

  {/* Floating interactive terminal. Placed high in the DOM so client:visible
      hydrates on load; the launcher is position:fixed (bottom-right). */}
  <Terminal client:visible />

  <main>
    <Hero />

    <Section id="work" label="work">
      <div class="cards">
        {liveProjects.map((p) => <ProductCard project={p} />)}
      </div>
    </Section>

    <Section id="building" label="building">
      <div class="building-panel">
        {devProjects.map((p) => <StatusRow project={p} />)}
      </div>
    </Section>

    <Section label="capabilities">
      <ul class="chips">
        {capabilities.map((c) => <li><Chip>{c}</Chip></li>)}
      </ul>
    </Section>

    <Section id="about" label="about">
      <p class="about-copy">{profile.about}</p>
    </Section>

    <Section id="contact" label="contact">
      <p class="contact-line">{profile.contactLine}</p>
      <div class="contact-actions">
        <Button variant="primary" href={`mailto:${profile.email}`}>
          {profile.email}
        </Button>
      </div>
      <ul class="contact-links mono">
        {
          socials.map((s) => (
            <li>
              <a href={s.href} target="_blank" rel="noopener noreferrer">{s.label}</a>
            </li>
          ))
        }
      </ul>
    </Section>
  </main>

  <Footer />
</Base>

<style>
  .ticker {
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  .ticker-inner {
    max-width: var(--container);
    margin-inline: auto;
    padding: 0.4rem var(--container-pad);
    display: flex;
    gap: 1.75rem;
    font-size: 11px;
    letter-spacing: 0.06em;
  }

  .ticker-item {
    display: inline-flex;
    gap: 0.5rem;
  }

  .ticker .sym {
    color: var(--text-muted);
  }

  .ticker .val {
    color: var(--text-faint);
  }

  /* Work — two cards side by side, stacked on mobile */
  .cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 720px) {
    .cards {
      grid-template-columns: 1fr;
    }
  }

  /* Building — one bordered panel holding the terminal-style status rows */
  .building-panel {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  /* Capabilities — flat mono chip strip, no colour */
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  /* About — single readable column */
  .about-copy {
    max-width: 640px;
    margin: 0;
    color: var(--text-muted);
  }

  /* Contact */
  .contact-line {
    max-width: 480px;
    margin: 0;
    color: var(--text-muted);
  }

  .contact-actions {
    margin-top: 1.5rem;
  }

  .contact-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin: 1.75rem 0 0;
    padding: 0;
    list-style: none;
    font-size: 13px;
  }

  .contact-links a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 150ms ease;
  }

  .contact-links a:hover {
    color: var(--text);
  }

  .contact-links a:focus-visible {
    outline: 1px solid var(--accent);
    outline-offset: 3px;
    border-radius: 3px;
  }
</style>
