---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Section from "../components/Section.astro";
import Hero from "../components/Hero.astro";
import ProductCard from "../components/ProductCard.astro";
import StatusRow from "../components/StatusRow.astro";
import { projects } from "../data/projects";

const liveProjects = projects.filter((p) => p.status === "live");
const devProjects = projects.filter((p) => p.status === "dev");
---

<Base>
  {/* Ticker strip — Phase 7 replaces this with <Ticker client:load />. */}
  {/* No fake numbers: values are dim placeholders until the live island mounts. */}
  <div class="ticker" aria-label="Crypto ticker">
    <div class="ticker-inner mono">
      <span class="ticker-item"><span class="sym">BTC</span><span class="val">—</span></span>
      <span class="ticker-item"><span class="sym">ETH</span><span class="val">—</span></span>
      <span class="ticker-item"><span class="sym">SOL</span><span class="val">—</span></span>
    </div>
  </div>

  <Nav />

  <main>
    <Hero />

    <Section id="work" label="work">
      <div class="cards">
        {liveProjects.map((p) => <ProductCard project={p} />)}
      </div>
    </Section>

    <Section id="building" label="building">
      <div class="building-panel">
        {devProjects.map((p) => <StatusRow project={p} />)}
      </div>
    </Section>

    <Section id="about" label="about — phase 5">
      <p style="color: var(--text-muted); margin: 0;">About + contact go here.</p>
    </Section>
  </main>

  <Footer />
</Base>

<style>
  .ticker {
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  .ticker-inner {
    max-width: var(--container);
    margin-inline: auto;
    padding: 0.4rem var(--container-pad);
    display: flex;
    gap: 1.75rem;
    font-size: 11px;
    letter-spacing: 0.06em;
  }

  .ticker-item {
    display: inline-flex;
    gap: 0.5rem;
  }

  .ticker .sym {
    color: var(--text-muted);
  }

  .ticker .val {
    color: var(--text-faint);
  }

  /* Work — two cards side by side, stacked on mobile */
  .cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 720px) {
    .cards {
      grid-template-columns: 1fr;
    }
  }

  /* Building — one bordered panel holding the terminal-style status rows */
  .building-panel {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }
</style>
