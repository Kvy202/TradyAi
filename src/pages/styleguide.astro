---
import Base from "../layouts/Base.astro";
import Section from "../components/Section.astro";
import Button from "../components/Button.astro";
import StatusDot from "../components/StatusDot.astro";
import Chip from "../components/Chip.astro";

const tech = [
  "Python",
  "FastAPI",
  "React",
  "Node.js",
  "Socket.io",
  "MongoDB",
  "Kotlin / Android",
  "AWS",
];
---

<Base title="styleguide — tradyai">
  <main>
    <Section label="styleguide" id="top">
      <h1 style="font-weight: 500; letter-spacing: -0.01em; margin: 0;">
        Primitives
      </h1>
      <p class="sg-note mono">
        Temporary preview — deleted in Phase 8. Only --accent carries colour.
      </p>
    </Section>

    <Section label="Button — variants">
      <div class="sg-row">
        <Button variant="primary" href="#top">Explore work</Button>
        <Button variant="primary" href="#top" arrow="right">Explore work</Button>
        <Button variant="ghost" href="#top">Launch Pulse</Button>
        <Button variant="ghost" href="https://example.com" external arrow="external">
          Launch Pulse
        </Button>
        <Button variant="primary">As button (no href)</Button>
      </div>
    </Section>

    <Section label="StatusDot — live / dev">
      <div class="sg-row sg-row--align">
        <span class="sg-inline mono">
          <StatusDot status="live" /> live
        </span>
        <span class="sg-inline mono">
          <StatusDot status="dev" /> in dev
        </span>
      </div>
    </Section>

    <Section label="Chip — tech / skills">
      <div class="sg-row">
        {tech.map((t) => <Chip>{t}</Chip>)}
      </div>
    </Section>

    <Section label="Section — vertical rhythm + container">
      <p style="color: var(--text-muted); max-width: 640px; margin: 0;">
        This text sits inside a <span class="mono">Section</span>: max-width
        1100px container, horizontal padding clamp(20px, 5vw, 40px), and
        section vertical rhythm clamp(64px, 10vh, 120px). The label above each
        block is the optional mono section label.
      </p>
    </Section>
  </main>

  <style>
    .sg-note {
      color: var(--text-faint);
      font-size: 12px;
      margin-top: 0.75rem;
    }

    .sg-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .sg-row--align {
      align-items: center;
      gap: 2rem;
    }

    .sg-inline {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 13px;
      color: var(--text-muted);
    }
  </style>
</Base>
